   "source": [
    "P = float(input(\"Enter Principal: \"))\n",
    "R = float(input(\"Enter Rate: \"))\n",
    "N = float(input(\"Number of times interest is compunded per year: \"))\n",
    "T = float(input(\"Enter Time (year): \"))\n",
    "\n",
    "A = P * (1 + (R/100)/N) ** (N*T)\n",
    "print(\"Compound Interest =\", A)\n"
   ]
